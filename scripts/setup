#!/usr/bin/env bash
# loom bootstrap
#
# Creates the Cloudflare resources loom needs (R2 buckets, KV namespace,
# D1 database) and prints a wrangler.jsonc fragment with the IDs filled
# in. Idempotent — safe to re-run.
#
# Prerequisites:
#   - wrangler logged in (`wrangler login`)
#   - pnpm + Node 22 installed

set -euo pipefail

# shellcheck disable=SC2034
COL_GREEN='\033[0;32m'; COL_YELLOW='\033[0;33m'; COL_RED='\033[0;31m'; COL_RESET='\033[0m'

log()   { printf "${COL_GREEN}[loom]${COL_RESET} %s\n" "$*"; }
warn()  { printf "${COL_YELLOW}[loom]${COL_RESET} %s\n" "$*"; }
fatal() { printf "${COL_RED}[loom]${COL_RESET} %s\n" "$*" >&2; exit 1; }

command -v pnpm >/dev/null || fatal "pnpm not found. Install it first."
command -v wrangler >/dev/null || pnpm dlx wrangler --version >/dev/null

log "Installing dependencies…"
pnpm install --frozen-lockfile

log "Provisioning Cloudflare resources. This is idempotent."
# TODO(M1): actually call wrangler commands to create:
#   - R2 buckets:         loom-workspace-snapshots, loom-publications
#   - KV namespace:       loom-platform
#   - D1 database:        loom-platform
# ...then print a wrangler.jsonc fragment with the discovered IDs.

cat <<'EOF'

Not implemented yet — this is the M0 stub. Until M1 lands, provision
resources manually with:

    wrangler r2 bucket create loom-workspace-snapshots
    wrangler r2 bucket create loom-publications
    wrangler kv:namespace create loom-platform
    wrangler d1 create loom-platform

Then copy the IDs into apps/web/wrangler.jsonc and set secrets per
docs/DEPLOYMENT.md.

EOF
