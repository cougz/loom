# Copy to .dev.vars (for `wrangler dev`) or set as Workers secrets
# (`wrangler secret put NAME`) for production. Never commit actual values.

# ── Cloudflare Access (gates /dash and /mcp; /view is public) ─────────
# Your team's Access domain — see Zero Trust → Settings → General.
CF_ACCESS_TEAM_DOMAIN=yourcompany.cloudflareaccess.com

# The Access application's AUD tag (hex string, ~64 chars).
# Dashboard → Zero Trust → Access → Applications → <your app> → Overview.
CF_ACCESS_AUD=

# ── Cloudflare account + API ──────────────────────────────────────────
# Your account ID (from `wrangler whoami`).
CF_ACCOUNT_ID=

# API token used by loom's MCP tools to drive the CF REST API on behalf
# of users. Required scopes — see docs/DEPLOYMENT.md for the full list:
#   Workers R2 Storage: Edit
#   Workers KV Storage: Edit
#   D1: Edit
#   Workers AI: Read
#   Browser Rendering: Edit
#   (zone) DNS: Edit
CF_API_TOKEN=

# ── Platform secrets ──────────────────────────────────────────────────
# HMAC secret for the session-scoped JWT loom mints so sandboxes can call
# /mcp without Access interactive flow. Generate with: openssl rand -base64 32
PLATFORM_JWT_SECRET=

# ── Configuration (also in wrangler.jsonc vars, repeat for local) ─────
LOOM_HOSTNAME=loom.yourcompany.com
SANDBOX_TRANSPORT=ws
