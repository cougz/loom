# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.output/
.vinxi/
.tanstack/
.wrangler/

# Env / secrets
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*

# Deployment config (generated by ./scripts/setup — never committed)
apps/web/.deploy-env
apps/web/wrangler.local.jsonc

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# TypeScript build info
*.tsbuildinfo

# Coverage
coverage/

# OpenCode UI build artifact (generated by scripts/build-opencode-ui).
# Only VERSION and embed.html are checked in; the mount bundle (JS/CSS
# chunks + assets) is built from the pinned OpenCode commit.
apps/web/public/opencode-ui/*
!apps/web/public/opencode-ui/VERSION
!apps/web/public/opencode-ui/embed.html

# Cached OpenCode clone used by scripts/build-opencode-ui
.cache/
