{
  "name": "@loom/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The loom Worker — /dash UI and /mcp server. Single Cloudflare Workers deployment.",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "../../scripts/build-opencode-ui",
    "build": "vite build",
    "deploy": "../../scripts/gen-wrangler-config && WRANGLER_LOG=${WRANGLER_LOG:-debug} wrangler deploy --config wrangler.local.jsonc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/agents": "^0.0.16",
    "@cloudflare/kumo": "^1.19.0",
    "@cloudflare/sandbox": "0.8.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/react": "^2.1.7",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.89.0",
    "@tanstack/start": "^1.89.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^0.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.1.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
